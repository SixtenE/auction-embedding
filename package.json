{
  "name": "auction-embedding",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "cd frontend && bun install --frozen-lockfile && bun run build && cd .. && bun build src/index.ts --outdir dist --target=bun",
    "start": "bun run dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "seed:unsplash": "bun run scripts/seed-unsplash.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1013.0",
    "@aws-sdk/s3-request-presigner": "^3.1013.0",
    "@google/genai": "^1.46.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "vitest": "^4.1.0"
  }
}
