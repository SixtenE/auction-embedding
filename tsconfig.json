{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun-types"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts", "drizzle.config.ts"]
}
