# App
PORT=3000

# Postgres (docker-compose default)
DATABASE_URL=postgresql://auction:auction@localhost:5432/auction

# Gemini
GEMINI_API_KEY=

# Embedding model + dimension
EMBEDDING_MODEL=gemini-embedding-2-preview
EMBEDDING_DIM=3072

# Qdrant (vector DB)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=images
# QDRANT_API_KEY=

# S3-compatible (MinIO local — create bucket "images" in console http://localhost:9001)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio_secret
S3_BUCKET=images
# Presigned GET expiry (seconds); default 3600
# S3_PRESIGN_EXPIRES_SECONDS=3600

# Limits
MAX_UPLOAD_BYTES=10485760
DEFAULT_TOP_K=10
